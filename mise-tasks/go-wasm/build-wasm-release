#!/usr/bin/env bash
#MISE description="Build the Go/WASM bridge in release mode"
set -euo pipefail

cd "${MISE_PROJECT_ROOT}"
cargo build --package secure-tunnel-go-wasm --target wasm32-wasip1 --release
cp target/wasm32-wasip1/release/secure_tunnel_go_wasm.wasm crates/go-wasm/go/secure_tunnel_go_wasm.wasm \
    || cp target/wasm32-wasip1/release/secure_tunnel_go.wasm crates/go-wasm/go/secure_tunnel_go_wasm.wasm

cd "${MISE_PROJECT_ROOT}/crates/go-wasm/go"
go mod tidy
